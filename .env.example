# CS2 Market Analyzer - Backend Configuration

# Database
# Get DATABASE_URL from Supabase: https://supabase.com/dashboard/project/_/settings/database
# Format: postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgresql://user:password@db.supabase.co:5432/postgres

# Environment
ENVIRONMENT=production
DEBUG=false

# CSMarketAPI Keys (optional - for multi-market backfill)
# Each key gets 1,000 free requests/month. Up to 4 keys supported.
# CSMARKETAPI_KEY_1=your_key_here
# CSMARKETAPI_ACCOUNT_1=account_name
# CSMARKETAPI_KEY_2=your_key_2_here
# CSMARKETAPI_ACCOUNT_2=account_name_2
