backend/venv/
backend/__pycache__/
backend/*.pyc
backend/*.pyo
backend/*.egg-info/
backend/.pytest_cache/
backend/dist/
backend/build/

# Frontend - Node
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/dist/
frontend/.turbo/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Database
*.db
*.sqlite
*.sqlite3

